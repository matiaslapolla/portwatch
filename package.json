{
	"name": "portwatch",
	"version": "0.2.0",
	"description": "Watch, free and kill the processes holding your local ports — built for the AI/agentic-coding era. TUI + scriptable commands + MCP server.",
	"type": "module",
	"bin": {
		"portwatch": "dist/cli.js"
	},
	"files": [
		"dist"
	],
	"keywords": [
		"port",
		"ports",
		"kill",
		"dev-server",
		"lsof",
		"tui",
		"mcp",
		"ai",
		"agent",
		"claude-code",
		"cursor",
		"localhost",
		"process"
	],
	"engines": {
		"node": ">=18"
	},
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/matiaslapolla/portwatch.git"
	},
	"scripts": {
		"build": "tsc",
		"postbuild": "chmod +x dist/cli.js",
		"dev": "tsc --watch",
		"start": "node dist/cli.js",
		"test": "node --test --import tsx $(find source -name '*.test.ts')",
		"prepublishOnly": "npm run build"
	},
	"dependencies": {
		"@modelcontextprotocol/sdk": "^1.21.0",
		"ink": "^7.0.5",
		"react": "^19.2.7",
		"zod": "^3.25.0"
	},
	"devDependencies": {
		"@types/node": "^25.9.1",
		"@types/react": "^19.2.16",
		"tsx": "^4.19.2",
		"typescript": "^6.0.3"
	}
}
