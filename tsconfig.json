{
	"compilerOptions": {
		"target": "ES2022",
		"module": "NodeNext",
		"moduleResolution": "NodeNext",
		"jsx": "react-jsx",
		"lib": ["ES2022"],
		"types": ["node"],
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"declaration": false,
		"outDir": "dist",
		"rootDir": "source"
	},
	"include": ["source"],
	"exclude": ["source/**/*.test.ts"]
}
